NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=server-only-service-role-key

# Exact HTTPS destination. Never accept a redirect URL from a visitor.
TELEGRAM_CHANNEL_URL=https://t.me/your_official_channel

META_PIXEL_ID=123456789012345
META_ACCESS_TOKEN=server-only-meta-access-token
META_API_VERSION=v21.0
META_TEST_EVENT_CODE=
CONVERSION_INTERNAL_SECRET=server-only-secret-for-confirmed-purchases
TRACKING_ALLOWED_ORIGINS=https://your-landing-page.framer.website

# Used only to hash an IP for a short-lived rate-limit key. Raw IPs are never stored.
IP_HASH_SALT=replace-with-a-long-random-value
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_SECONDS=60
DATA_RETENTION_DAYS=365

# Set to false only for local development without Supabase.
NEXT_PUBLIC_ANALYTICS_ENABLED=true
CLIENT_PORTAL_URL=https://app.orionscalper.com
# Legacy releases only: exact comma-separated external hosts approved for protected proxy downloads.
# New EA builds use the private Supabase Storage release bucket instead.
PRODUCT_DOWNLOAD_HOSTS=downloads.orionscalper.com
RESEND_API_KEY=server-only-resend-api-key
RENEWAL_EMAIL_FROM=Orion Scalper <no-reply@orionscalper.com>
CRON_SECRET=replace-with-a-long-random-secret
